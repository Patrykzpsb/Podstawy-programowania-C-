#include <iostream>
using namespace std;

int main() {
    int liczbaCalkowita = 42;
    float liczbaPrzecinkowa = 3.14f;
    char znak = 'A';
    bool wartosc = true;
    
    cout << "int: " << liczbaCalkowita << endl;
    cout << "float: " << liczbaPrzecinkowa << endl;
    cout << "char: " << znak << endl;
    cout << "bool: " << wartosc << endl;
    
    return 0;
}